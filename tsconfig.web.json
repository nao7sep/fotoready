{
  // Renderer side: DOM, NO Node. `types: ["vite/client"]` deliberately omits
  // @types/node, so a renderer file that reaches for a Node global (process,
  // Buffer) or imports a `node:*` builtin fails to compile — it would be broken in
  // the sandboxed renderer at runtime. Preload is checked by tsconfig.node.json,
  // not here, precisely so its `electron` import can't drag @types/node back into
  // this program.
  "compilerOptions": {
    "composite": true,
    "outDir": "./out/tsbuild-web",
    "noEmit": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@renderer/*": ["./src/renderer/*"]
    }
  },
  "include": [
    "src/vite-env.d.ts",
    "src/renderer/**/*",
    "src/shared/**/*"
  ]
}
